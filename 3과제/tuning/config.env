# ===== 대회날 여기만 수정 =====
# 부하/채점 대상 정의. 새 애플리케이션을 받으면 채점기준표를 보고 아래를 채운다.
# loadtest.sh / autotune.sh 가 이 파일을 source 한다.

# 공통 식별자(앱이 요구하면). 안 쓰면 비워둬도 됨.
UUID=${UUID:-7c5a3c6a-758f-4bc5-9bdf-3e573a0ad729}

# 측정 전에 한 번 넣어둘 시드 레코드 (GET 부하가 실제 행을 맞히게).
#   형식: "METHOD|path|json_body"   (GET 이면 body 비움)
SEEDS=(
  "POST|/v1/user|{\"requestid\":\"1\",\"uuid\":\"$UUID\",\"username\":\"loadseed1\",\"email\":\"loadseed1@example.org\"}"
  "POST|/v1/product|{\"requestid\":\"1\",\"uuid\":\"$UUID\",\"id\":\"loadseedp1\",\"name\":\"loadseedp1\",\"price\":1}"
)

# 부하 대상 API 목록.
#   형식: "name|slo_sec|conc|qps|METHOD|path(쿼리포함)|json_body"
#   - name      : 결과 라벨 + (autotune 에서) 같은 이름의 Deployment 를 튜닝
#   - slo_sec   : 채점기준의 성능 SLO (이 시간 이내 = perf OK)
#   - conc/qps  : hey -c / -q
#   - METHOD    : GET | POST
#   - body      : POST 일 때 JSON, GET 이면 비움
APIS=(
  "user|0.2|30|10|GET|/v1/user?email=loadseed1@example.org&requestid=1&uuid=$UUID|"
  "product|0.2|30|10|GET|/v1/product?id=loadseedp1&requestid=1&uuid=$UUID|"
  "stress|1.0|12|2|POST|/v1/stress|{\"requestid\":\"1\",\"uuid\":\"$UUID\",\"length\":64}"
)

# 가용성 합격선(%) — 이 밑이면 autotune 점수에서 실격 처리.
AVAIL_GATE=${AVAIL_GATE:-99}
# 노드 1대(평균) 초과당 비용 패널티 점수.
COST_PENALTY=${COST_PENALTY:-6}
# 쿠버네티스 네임스페이스.
NS=${NS:-app}
